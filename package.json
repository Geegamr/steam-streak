{
  "name": "steam-streak",
  "version": "1.0.0",
  "type": "module",
  "description": "Track your daily Steam visits and game streaks",
  "private": true,
  "scripts": {
    "dev": "millennium-ttc --build dev",
    "watch": "millennium-ttc --build dev --watch",
    "build": "millennium-ttc --build prod && npm run copy",
    "copy": "node -e \"require('fs').copyFileSync('.millennium/Dist/index.js', 'index.js'); require('fs').copyFileSync('.millennium/Dist/webkit.js', 'webkit.js'); console.log('Files copied successfully');\""
  },
  "dependencies": {
    "@steambrew/api": "^5.5.3",
    "@steambrew/client": "^5.8.4",
    "@steambrew/ttc": "^2.8.7",
    "@steambrew/webkit": "^5.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
